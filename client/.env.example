# DINA client environment (copy to .env.local for dev; set real values in CI/host).
# Vite only exposes vars prefixed with VITE_ to the browser bundle.

# Base path of the DINA API. In dev, leave as the same-origin prefix and let the
# Vite proxy (vite.config.ts) forward /dina → the server. In production the SPA
# is served same-origin with the API, so this stays a relative path.
VITE_API_BASE=/dina/api/v1

# Dev-only: where the Vite proxy forwards /dina during `npm run dev`.
VITE_DEV_API_TARGET=https://localhost:8445

# Optional build metadata surfaced in the UI footer.
VITE_APP_NAME=DINA
